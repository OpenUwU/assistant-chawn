{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"incremental": true,
		"tsBuildInfoFile": "./dist/.tsbuildinfo",
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": false,
		"sourceMap": false,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitOverride": true
	},
	"include": ["src/**/*"]
}
