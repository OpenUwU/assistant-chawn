{
	"name": "assistant-chawn",
	"version": "1.0.0",
	"description": "Lightweight uer installable discord bot",
	"main": "dist/index.js",
	"type": "module",
	"repository": "https://github.com/openUwU/assistant-chawn",
	"author": "bre4d777 and collaborators",
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"format": "biome format --write .",
		"lint": "biome lint  .",
		"lint:fix": "biome lint --write .",
		"dev": "tsx watch src/index.ts",
		"prepare": "husky",
		"add-headers": "node scripts/add-header.js",
		"commit": "cz",
		"migrate": "tsx scripts/migrate.ts",
		"migrate:dry": "tsx scripts/migrate.ts --dry"
	},
	"lint-staged": {
		"*.{ts,js}": [
			"node scripts/add-header.js --stage",
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@biomejs/biome": "^2.5.0",
		"@sourcebin/linguist": "^0.0.3",
		"discord.js": "^14.16.3",
		"dotenv": "^16.4.5",
		"ioredis": "^5.11.1",
		"pg": "^8.22.0",
		"qr": "^0.6.0",
		"sharp": "^0.35.2"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@types/node": "^22.7.5",
		"@types/pg": "^8.20.0",
		"commitizen": "^4.3.2",
		"cz-conventional-changelog": "^3.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"tsx": "^4.19.1",
		"typescript": "^5.6.3"
	},
	"engines": {
		"node": ">=18.17.0"
	}
}
